generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  USER
}

enum BusinessUserRole {
  OWNER
  ADMIN
  SALES
  INVENTORY
  ORDER_MANAGER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum FeatureSource {
  PLAN
  OVERRIDE
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum TrainingStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum InvestmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String?
  platformRole PlatformRole   @default(USER)
  memberships  BusinessUser[]
  customers    Customer[]
  payments     Payment[]      @relation("PaymentConfirmedBy")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Business {
  id                    String                   @id @default(cuid())
  name                  String
  slug                  String                   @unique
  logoUrl               String?
  description           String?
  email                 String
  phone                 String
  address               String
  currency              String                   @default("NGN")
  themeColor            String                   @default("#047857")
  status                BusinessStatus           @default(ACTIVE)
  memberships           BusinessUser[]
  features              BusinessFeature[]
  subscriptions         BusinessSubscription[]
  categories            Category[]
  products              Product[]
  customers             Customer[]
  carts                 Cart[]
  orders                Order[]
  payments              Payment[]
  bankAccounts          BankAccount[]
  deliveryZones         DeliveryZone[]
  trainingPrograms      TrainingProgram[]
  trainingEnrollments   TrainingEnrollment[]
  investmentPlans       InvestmentPlan[]
  investmentSubscribers InvestmentSubscription[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

model BusinessUser {
  id         String           @id @default(cuid())
  businessId String
  userId     String
  role       BusinessUserRole
  status     MembershipStatus @default(ACTIVE)
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([businessId, userId])
  @@index([userId])
}

model FeatureDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  isCore      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessFeature {
  id         String        @id @default(cuid())
  businessId String
  featureKey String
  enabled    Boolean       @default(true)
  source     FeatureSource @default(PLAN)
  business   Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([businessId, featureKey])
  @@index([featureKey])
}

model SubscriptionPlan {
  id         String                    @id @default(cuid())
  name       String                    @unique
  price      Decimal                   @db.Decimal(12, 2)
  interval   String                    @default("monthly")
  status     String                    @default("ACTIVE")
  features   SubscriptionPlanFeature[]
  businesses BusinessSubscription[]
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
}

model SubscriptionPlanFeature {
  id         String           @id @default(cuid())
  planId     String
  featureKey String
  plan       SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model BusinessSubscription {
  id                 String           @id @default(cuid())
  businessId         String
  planId             String
  status             String           @default("ACTIVE")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  business           Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan @relation(fields: [planId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([businessId])
  @@index([planId])
}

model Category {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  slug        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
}

model Product {
  id             String         @id @default(cuid())
  businessId     String
  categoryId     String?
  name           String
  slug           String
  description    String
  price          Decimal        @db.Decimal(12, 2)
  compareAtPrice Decimal?       @db.Decimal(12, 2)
  stockQuantity  Int            @default(0)
  unit           String
  status         ProductStatus  @default(DRAFT)
  isFeatured     Boolean        @default(false)
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category       Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images         ProductImage[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Customer {
  id                      String                   @id @default(cuid())
  businessId              String
  userId                  String?
  name                    String
  email                   String?
  phone                   String
  defaultAddress          String?
  business                Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                    User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  carts                   Cart[]
  orders                  Order[]
  trainingEnrollments     TrainingEnrollment[]
  investmentSubscriptions InvestmentSubscription[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([businessId])
  @@index([userId])
}

model Cart {
  id         String     @id @default(cuid())
  businessId String
  customerId String?
  sessionId  String?
  status     CartStatus @default(ACTIVE)
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([businessId])
  @@index([customerId])
  @@index([sessionId])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id              String        @id @default(cuid())
  businessId      String
  customerId      String?
  orderNumber     String
  customerName    String
  customerEmail   String?
  customerPhone   String
  deliveryAddress String?
  deliveryMethod  String
  paymentMethod   String
  paymentStatus   PaymentStatus @default(PENDING)
  orderStatus     OrderStatus   @default(PENDING)
  subtotal        Decimal       @db.Decimal(12, 2)
  deliveryFee     Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  notes           String?
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        Payment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([businessId, orderNumber])
  @@index([businessId])
  @@index([customerId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unit        String
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Payment {
  id                String        @id @default(cuid())
  businessId        String
  orderId           String?
  amount            Decimal       @db.Decimal(12, 2)
  method            String
  status            PaymentStatus @default(PENDING)
  reference         String?
  confirmedByUserId String?
  confirmedAt       DateTime?
  business          Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order             Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  confirmedBy       User?         @relation("PaymentConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime      @default(now())

  @@index([businessId])
  @@index([orderId])
}

model BankAccount {
  id            String   @id @default(cuid())
  businessId    String
  bankName      String
  accountName   String
  accountNumber String
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

model DeliveryZone {
  id         String   @id @default(cuid())
  businessId String
  name       String
  fee        Decimal  @db.Decimal(12, 2)
  isActive   Boolean  @default(true)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, name])
}

model TrainingProgram {
  id          String               @id @default(cuid())
  businessId  String
  title       String
  slug        String
  description String
  price       Decimal              @db.Decimal(12, 2)
  startDate   DateTime
  endDate     DateTime
  location    String
  onlineLink  String?
  capacity    Int
  instructor  String
  imageUrl    String?
  status      TrainingStatus       @default(DRAFT)
  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enrollments TrainingEnrollment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
}

model TrainingEnrollment {
  id                String           @id @default(cuid())
  businessId        String
  trainingProgramId String
  customerId        String?
  customerName      String
  customerEmail     String?
  customerPhone     String
  paymentStatus     PaymentStatus    @default(PENDING)
  enrollmentStatus  EnrollmentStatus @default(PENDING)
  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  trainingProgram   TrainingProgram  @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  customer          Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([businessId])
  @@index([trainingProgramId])
}

model InvestmentPlan {
  id                    String                   @id @default(cuid())
  businessId            String
  name                  String
  slug                  String
  description           String
  minimumAmount         Decimal                  @db.Decimal(12, 2)
  maximumAmount         Decimal?                 @db.Decimal(12, 2)
  durationDays          Int
  expectedReturnText    String
  riskNote              String
  terms                 String
  status                InvestmentStatus         @default(DRAFT)
  business              Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  investmentSubscribers InvestmentSubscription[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
}

model InvestmentSubscription {
  id               String         @id @default(cuid())
  businessId       String
  investmentPlanId String
  customerId       String?
  amount           Decimal        @db.Decimal(12, 2)
  paymentStatus    PaymentStatus  @default(PENDING)
  startDate        DateTime
  maturityDate     DateTime
  payoutStatus     PayoutStatus   @default(PENDING)
  acceptedTermsAt  DateTime
  business         Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  investmentPlan   InvestmentPlan @relation(fields: [investmentPlanId], references: [id], onDelete: Cascade)
  customer         Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([businessId])
  @@index([investmentPlanId])
  @@index([customerId])
}
